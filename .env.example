# ──────────────────────────────────────────────────────────────
# Capsule Backend — Environment Variables
# Copy to .env and fill in required values.
# ──────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────

# Environment name: development | staging | production
CAPSULE_ENV=development

# HTTP port the backend listens on
CAPSULE_PORT=8080

# Log level: debug | info | warn | error
CAPSULE_LOG_LEVEL=info

# Secret key for JWT signing (required in all environments)
CAPSULE_SECRET_KEY=change-me-to-a-random-32-char-string

# Public-facing hostname for the API (used in DB connection URLs, etc.)
# Example: api.your-domain.com
CAPSULE_PUBLIC_HOST=

# Platform subdomain base (apps served at <slug>.CAPSULE_APPS_DOMAIN)
# Example: apps.your-domain.com
CAPSULE_APPS_DOMAIN=

# ── Database & Cache ──────────────────────────────────────────

# PostgreSQL connection URL (required)
DATABASE_URL=postgres://capsule:capsule@localhost:5432/capsule?sslmode=disable

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ── Security & CORS ───────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# In production this is required; in development defaults to localhost:3000.
# Example: https://app.your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────

RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ── AWS ───────────────────────────────────────────────────────

AWS_DEFAULT_REGION=us-east-1

# Your 12-digit AWS account ID — used to derive default bucket names
AWS_ACCOUNT_ID=

# ECR registry URL (e.g. 123456789012.dkr.ecr.us-east-1.amazonaws.com)
ECR_REGISTRY=

# S3 bucket for deployment artifacts (defaults to capsule-artifacts-<account_id>)
ARTIFACTS_BUCKET=

# S3 bucket for static assets (defaults to capsule-static-<account_id>)
CAPSULE_STATIC_BUCKET=

# ── Infrastructure ────────────────────────────────────────────

# DNS name of the Application Load Balancer (used for custom domain CNAME)
ALB_DNS_NAME=

# RDS subnet group name for managed databases
DB_SUBNET_GROUP=capsule

# Security group ID to attach to RDS instances
RDS_SECURITY_GROUP_ID=
