# ──────────────────────────────────────────────────────────────
# Capsule Frontend — Environment Variables
# Copy to .env.local and fill in values for your environment.
# ──────────────────────────────────────────────────────────────

# Backend API base URL (used for all client-side API calls)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL for real-time log streaming
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Platform apps subdomain base (e.g. apps.your-domain.com)
# Used to build default deployment URLs shown in the dashboard.
NEXT_PUBLIC_APP_DOMAIN=

# Internal backend URL used by Next.js server-side routes/rewrites
# (typically the same as NEXT_PUBLIC_API_URL in local dev)
BACKEND_INTERNAL_URL=http://localhost:8080

